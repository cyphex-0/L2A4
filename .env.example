# ---------------------------------------------
# Environment Variables for RentNest API
# ---------------------------------------------

# Application Port (Render automatically sets this, but you can define it locally)
PORT=5000

# Environment (development or production)
NODE_ENV=production

# Database Connection (Ensure this is a PostgreSQL connection string)
# For Render, use the "Internal Database URL" if deploying a DB on Render,
# or the External URL (e.g. Supabase, Neon) if hosted elsewhere.
DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public"

# JWT Secrets
# Generate random secure strings for these (e.g., using `openssl rand -hex 32`)
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_SECRET="your-super-secret-refresh-key"
JWT_REFRESH_EXPIRES_IN="30d"

# Stripe Payment Keys
# Get these from your Stripe Dashboard (Developers -> API Keys)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Admin Seeding (Used by prisma/seed.ts)
SEED_ADMIN_EMAIL="admin@rentnest.com"
SEED_ADMIN_PASSWORD="RentNestAdmin2026"
